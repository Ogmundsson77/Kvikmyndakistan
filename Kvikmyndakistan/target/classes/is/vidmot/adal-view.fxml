<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="is.vidmot.controller.AdalController">
      <padding>
          <Insets bottom="10" left="10" right="10" top="10" />
      </padding>
      <children>
      <Label text="Ferðaplan">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <ListView fx:id="fxListiFerdir"  prefHeight="200.0" prefWidth="200.0" />
      <ButtonBar prefHeight="40.0" prefWidth="200.0">
         <buttons>
            <Button fx:id="fxSkoda" mnemonicParsing="false" onAction="#onSkoda" prefHeight="25.0" prefWidth="160.0" text="Skoða" />
            <Button mnemonicParsing="false" onAction="#onBaetaVid" text="Bæta við" />
            <Button fx:id="fxEyda" mnemonicParsing="false" onAction="#onEyda" text="Eyða" />
         </buttons>
      </ButtonBar>
      <Label fx:id="fxSkilabod" text="Veldu ferð til að skoða eða eyða">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      </children>
  </VBox>
